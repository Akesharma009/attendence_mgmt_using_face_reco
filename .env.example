# Copy this file to .env and adjust values, then `pip install python-dotenv`
# (already in requirements.txt) and load it, e.g. via `flask run` with
# python-dotenv auto-loading, or `from dotenv import load_dotenv` in run.py.

SECRET_KEY=replace-with-a-long-random-string

# --- Database -----------------------------------------------------------
# SQLite (default, zero config):
DATABASE_URL=sqlite:///instance/sms.db
# PostgreSQL:
# DATABASE_URL=postgresql+psycopg2://sms_user:password@localhost:5432/student_management
# MySQL:
# DATABASE_URL=mysql+pymysql://sms_user:password@localhost:3306/student_management

# --- Face recognition -----------------------------------------------------
FACE_MATCH_TOLERANCE=0.45
FACE_SAMPLES_PER_STUDENT=5
FACE_DETECTION_MODEL=hog
# hog = CPU (default, works everywhere)
# cnn = GPU accelerated (requires dlib built with CUDA support)

# --- Attendance rules ----------------------------------------------------
LATE_AFTER_MINUTES=15
